---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import FilterBar from "../components/Filterbar.astro";
import GalleryColumn from "../components/Gallerycolumn.astro";

import { sanity } from "../lib/sanity";

const products = await sanity.fetch(`
  *[_type == "product"]{
    _id,
    name,
    slug,
    image,
    collection
  }
`);

const columns = [[], [], []];

products.forEach((product, index) => {
  columns[index % 3].push(product);
});

const repeatedColumns = columns.map((column) =>
  Array.from({ length: 12 }, () => column).flat()
);

const speeds = [0.7, 1, 0.85];
---

<BaseLayout>
  <Header />
  <FilterBar />

  <section class="gallery-wrapper gallery-wrapper--no-js">
    {
      repeatedColumns.map((column, columnIndex) => (
        <GalleryColumn products={column} speed={speeds[columnIndex]} />
      ))
    }
  </section>
</BaseLayout>

<script>
  import { gsap } from "gsap";

  const prefersReducedMotion = window.matchMedia(
    "(prefers-reduced-motion: reduce)"
  ).matches;

  if (!prefersReducedMotion) {
    document
      .querySelector(".gallery-wrapper")
      .classList.remove("gallery-wrapper--no-js");

    const columns = document.querySelectorAll(".column");

    let target = 0;
    let current = 0;
    const ease = 0.05;

    window.addEventListener(
      "wheel",
      (e) => {
        target += e.deltaY * 0.8;
      },
      { passive: true }
    );

    function updateTabIndex() {
      const viewportHeight = window.innerHeight;

      document.querySelectorAll(".item").forEach((item) => {
        const rect = item.getBoundingClientRect();
        const inView = rect.bottom > 0 && rect.top < viewportHeight;
        item.tabIndex = inView ? 0 : -1;
      });
    }

    gsap.ticker.add(() => {
      current += (target - current) * ease;

      columns.forEach((column) => {
        const speed = parseFloat(column.dataset.speed);
        const contentHeight = column.scrollHeight / 2;

        let y = (current * speed) % contentHeight;

        if (y < 0) {
          y += contentHeight;
        }

        gsap.set(column, { y: -y });
      });

      updateTabIndex();
    });

    gsap.ticker.lagSmoothing(0);
  }
</script>

<style is:global>
  body {
    overflow: hidden;
  }

  .gallery-wrapper {
    position: fixed;
    inset: 0;
    overflow: hidden;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.2rem;
    padding: 6rem 1.2rem 1.2rem;
    background: #FFFBEA;
  }

  @media (max-width: 900px) {
    .gallery-wrapper {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .gallery-wrapper {
      grid-template-columns: 1fr;
    }
  }

  .gallery-wrapper--no-js {
    position: static !important;
    overflow: visible !important;
    height: auto !important;
  }

  body:has(.gallery-wrapper--no-js) {
    overflow: auto !important;
  }

  @media (prefers-reduced-motion: reduce) {
    .column {
      margin-top: 0 !important;
    }
  }
</style>