---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";

  const success =
    Astro.url.searchParams.get("success");

  const error =
    Astro.url.searchParams.get("error");
---

<BaseLayout>
  <Header />

  <section class="contact">
    <div class="left">
      <h1>
        Let’s talk.
      </h1>

      <div class="details">
        <div class="item">
          <p>
            <strong>Email</strong><br />
            hello@norstudio.com
          </p>
        </div>

        <div class="item">
          <p>
            <strong>Instagram</strong><br />
            @norstudio
          </p>
        </div>

        <div class="item">
          <p>
            <strong>Based in</strong><br />
            Amsterdam
          </p>
        </div>
      </div>
    </div>

    <form
      class="form"
      method="POST"
      action="/api/contact"
    >
      {
        success && (
          <p class="status success">
            Thanks, your message has been sent.
          </p>
        )
      }

      {
        error && (
          <p class="status error">
            Something went wrong.
          </p>
        )
      }

      <div class="field">
        <label for="name">Name</label>
        <input
            id="name"
            name="name"
            type="text"
            placeholder="Name"
            required
        />
      </div>

      <div class="field">
        <label for="email">Email</label>
        <input
            id="email"
            name="email"
            type="email"
            placeholder="Email"
            required
        />
      </div>

      <div class="field">
        <label for="message">Message</label>
        <textarea
            id="message"
            name="message"
            placeholder="Message"
            required
        />
      </div>

      <button type="submit">
        Send inquiry
      </button>
    </form>
  </section>
</BaseLayout>



<style>
  .contact {
    height: 100vh;

    display: grid;
    grid-template-columns:
      0.8fr
      1fr;

    align-items: center;

    gap: 4rem;

    padding:
      5.5rem
      1.2rem
      1.2rem;

    overflow: hidden;
  }

  .left {
    height: 100%;

    display: flex;
    flex-direction: column;

    justify-content: space-between;
  }

  h1 {
    font-size:
      clamp(
        4.5rem,
        7vw,
        8rem
      );

    line-height: 0.82;

    letter-spacing: -0.08em;

    font-weight: 400;

    max-width: 5ch;
  }

  .details {
    display: flex;
    flex-direction: column;

    gap: 1.6rem;
  }

  .item p {
    font-size: 1.4rem;

    line-height: 1.3;

    letter-spacing: -0.02em;
  }

  .item strong {
    font-weight: 500;
  }

  .form {
    display: flex;
    flex-direction: column;

    justify-content: center;

    gap: 1rem;
  }

  .field {
    border-bottom:
      1px solid
      rgba(0,0,0,.1);
  }

  input,
  textarea {
    width: 100%;

    border: none;

    background: transparent;

    font-family: inherit;

    color: inherit;

    font-size:
      clamp(
        1.8rem,
        2vw,
        2.8rem
      );

    letter-spacing: -0.05em;

    padding:
      1.2rem
      0;

    outline: none;
  }

  textarea {
    min-height: 10rem;

    resize: none;
  }

  input::placeholder,
  textarea::placeholder {
    color:
      rgba(0,0,0,.22);
  }

  button {
    width: fit-content;

    margin-top: 1rem;

    border: none;

    background: transparent;

    font-family: inherit;

    font-size: 1.4rem;

    cursor: pointer;

    padding: 0;

    position: relative;
  }

  button::after {
    content: "";

    position: absolute;

    left: 0;
    bottom: -0.3rem;

    width: 100%;
    height: 1px;

    background: black;

    transform: scaleX(0);

    transform-origin: left;

    transition:
      transform
      .7s
      cubic-bezier(.19,1,.22,1);
  }

  button:hover::after {
    transform: scaleX(1);
  }

  @media (max-width: 768px) {
    .contact {
      min-height: 100vh;
      height: auto;

      grid-template-columns: 1fr;

      gap: 3rem;

      padding-top: 7rem;

      overflow: visible;
    }

    .left {
      gap: 4rem;
    }

    h1 {
      font-size:
        clamp(
          4rem,
          14vw,
          6rem
        );
    }

    input,
    textarea {
      font-size: 2rem;
    }
  }

  .status {
    margin-bottom: 1rem;
    font-size: 1rem;
  }

  .success {
    color: green;
  }

  .error {
    color: red;
  }
</style>