---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import FilterBar from "../components/Filterbar.astro";
import GalleryColumn from "../components/Gallerycolumn.astro";

import { sanity } from "../lib/sanity";

const products = await sanity.fetch(`
  *[_type == "product"]{
    _id,
    name,
    slug,
    image,
    collection
  }
`);

const columns = [[], [], []];

products.forEach((product, index) => {
  columns[index % 3].push(product);
});

const repeatedColumns = columns.map((column) =>
  Array.from({ length: 12 }, () => column).flat()
);

const speeds = [0.7, 1, 0.85];
---

<BaseLayout>
  <Header />
  <FilterBar />

  <section class="gallery-wrapper">
    {
      repeatedColumns.map((column, columnIndex) => (
        <GalleryColumn products={column} speed={speeds[columnIndex]} />
      ))
    }
  </section>
</BaseLayout>

<script>
  const columns = document.querySelectorAll(".column");

  let current = 0;
  let target = 0;

  const ease = 0.05;

  window.addEventListener(
    "wheel",
    (e) => {
      target += e.deltaY * 0.8;
    },
    { passive: true }
  );

  function animate() {
    current += (target - current) * ease;

    columns.forEach((column) => {
      const speed = parseFloat(column.dataset.speed);
      const contentHeight = column.scrollHeight / 2;

      let y = (current * speed) % contentHeight;

      if (y < 0) {
        y += contentHeight;
      }

      column.style.transform = `translate3d(0, ${-y}px, 0)`;
    });

    requestAnimationFrame(animate);
  }

  animate();
</script>

<style>
  :global(body) {
    overflow: hidden;
  }

  .gallery-wrapper {
    position: fixed;

    inset: 0;

    overflow: hidden;

    display: grid;
    grid-template-columns: repeat(3, 1fr);

    gap: 1.2rem;

    padding: 6rem 1.2rem 1.2rem;

    background: #ececec;
  }

  @media (max-width: 900px) {
    .gallery-wrapper {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .gallery-wrapper {
      grid-template-columns: 1fr;
    }
  }
</style>