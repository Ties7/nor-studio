---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";

import { sanity } from "../../lib/sanity.js";
import { urlFor } from "../../lib/image.js";

export async function getStaticPaths() {
  const products = await sanity.fetch(`
    *[_type == "product" && defined(slug.current)]{
      slug
    }
  `);

  return products.map((product) => ({
    params: {
      slug: product.slug.current,
    },
  }));
}

const { slug } = Astro.params;

const product = await sanity.fetch(
  `
  *[_type == "product" && slug.current == $slug][0]{
    name,
    price,
    description,
    image,
    category
  }
`,
  { slug }
);
---

<BaseLayout>
  <Header />

  <section class="product">
    <div class="image-wrap">
      <img
        src={urlFor(product.image)
          .width(2000)
          .url()}
        alt={product.name}
      />
    </div>

    <div class="info">
      <div class="top">
        <h1>{product.name}</h1>

        <p class="category">
          {product.category}
        </p>
      </div>

      <p class="description">
        {product.description}
      </p>

      <p class="price">
        € {product.price}
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .product {
    min-height: 100vh;

    display: grid;
    grid-template-columns: 1.2fr 0.8fr;

    gap: 4rem;

    padding: 7rem 1.2rem 1.2rem;
  }

  .image-wrap {
    height: calc(100vh - 8.2rem);

    overflow: hidden;
  }

  img {
    width: 100%;
    height: 100%;

    object-fit: cover;

    display: block;
  }

  .info {
    display: flex;
    flex-direction: column;

    justify-content: space-between;

    padding: 1rem 0;
  }

  .top {
    display: flex;
    flex-direction: column;

    gap: 1rem;
  }

  h1 {
    font-size: clamp(4rem, 5vw, 8rem);

    font-weight: 400;

    line-height: 0.9;

    letter-spacing: -0.06em;
  }

  .category {
    font-size: 1.4rem;

    opacity: 0.5;
  }

  .description {
    max-width: 42rem;

    font-size: 1.6rem;

    line-height: 1.5;
  }

  .price {
    font-size: 2rem;

    font-weight: 500;
  }

  @media (max-width: 900px) {
    .product {
      grid-template-columns: 1fr;

      gap: 2rem;
    }

    .image-wrap {
      height: 70vh;
    }

    .info {
      gap: 4rem;
    }
  }
</style>